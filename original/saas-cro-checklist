currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle w-[22px] h-[22px] transition-colors text-[#ff3b1f]/40 hover:text-[#ff3b1f]" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle></svg></button><div class="flex-1 min-w-0"><button class="w-full text-left focus:outline-none group/title"><div class="flex items-center gap-2"><span class="flex-1 font-bold text-[#0b0b0c] text-[15px]" style="letter-spacing:-0.01em"><span class="mr-2 inline-block tabular-nums text-[11px] font-bold align-[1px] text-[#ff3b1f]" style="font-family:var(--font-jetbrains-mono), monospace;letter-spacing:0.04em" aria-hidden="true">042</span>Primary CTA uses an action verb in first person (&#x27;Start my free trial&#x27;)</span><div class="flex items-center gap-1.5 flex-shrink-0"><span class="inline-flex items-center text-[10px] font-extrabold uppercase tracking-wider px-2 py-1 bg-[#ff3b1f] text-white" style="transform:skew(-4deg)"><span style="transform:skew(4deg);display:inline-block">High Impact</span></span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down w-4 h-4 text-[#c9c5bb] group-hover/title:text-[#6b6b70] transition-all duration-200" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg></div></div></button><p class="text-[15px] text-[#2a2a2d] leading-[1.55] pr-4 overflow-hidden transition-all duration-200 max-h-0 opacity-0" aria-hidden="true">&#x27;Start my free trial&#x27; outperforms &#x27;Get started&#x27; and &#x27;Sign up&#x27; because the user mentally rehearses the action. Tiny copy change, consistent lift across B2B SaaS pages.</p></div></div><div class="flex items-start gap-3 py-3.5 px-4 rounded-xl border-[1.5px] transition-all duration-150 border-l-[3px] pl-[15px] border-[#ff3b1f]/35 border-l-[#ff3b1f] bg-[rgba(255,59,31,0.05)] hover:bg-[rgba(255,59,31,0.0